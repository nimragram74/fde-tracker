# ─────────────────────────────────────────────────────────────
# FDE Tracker — environment configuration
# Copy to `.env` for local dev. In Azure these are App Settings
# (provisioned automatically by `azd up` / Bicep).
# ─────────────────────────────────────────────────────────────

# ── Database (configurable) ──────────────────────────────────
# Default: Azure Database for PostgreSQL Flexible Server.
# The app is DB-configurable: point DATABASE_URL at any Postgres
# instance. To target Azure SQL instead, set DATABASE_PROVIDER=sqlserver
# and change prisma/schema.prisma `datasource.provider` (see README).
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://appuser:CHANGE_ME@localhost:5432/fdetracker?schema=public&sslmode=prefer"

# ── Auth.js / NextAuth (Microsoft Entra ID SSO) ──────────────
# Create an App Registration in Entra ID; add a web redirect URI:
#   https://<your-app>.azurewebsites.net/api/auth/callback/microsoft-entra-id
# (and http://localhost:3000/api/auth/callback/microsoft-entra-id for dev)
AUTH_SECRET="generate-with:  openssl rand -base64 32"
AUTH_MICROSOFT_ENTRA_ID_ID="<application-(client)-id>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<client-secret-value>"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# The canonical URL of the deployed app (used by Auth.js for callbacks).
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ── App configuration ────────────────────────────────────────
# Comma-separated Entra emails/UPNs that get the Admin role on first sign-in.
ADMIN_EMAILS="raghuram.nimishakavi@wipro.com"
# Default org name shown until an admin renames it in Settings.
DEFAULT_ORG_NAME="Wipro × Microsoft FDE Academy"
